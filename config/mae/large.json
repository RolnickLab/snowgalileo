{
    "training": {
        "num_epochs": 300,
        "batch_size": 64,
        "mask_ratio": 0.75,
        "patch_sizes": [1, 2, 3, 4, 5, 6, 7, 8],
        "start_lr": 0.0002,
        "max_lr": 0.001,
        "final_lr": 1.0e-06,
        "warmup_epochs": 0.1,
        "eval_eurosat_every_n_epochs": 10,
        "time_ratio": 0.25,
        "space_ratio": 0.25,
        "channel_ratio": 0.25,
        "spatial_patches_per_dim": 4,
        "loss": "norm_c_g"
    },
    "model": {
        "encoder": {
            "embedding_size": 128,
            "depth": 8,
            "mlp_ratio": 4,
            "num_heads": 8,
            "max_sequence_length": 24
        },
        "decoder": {
            "embedding_size": 128,
            "depth": 2,
            "mlp_ratio": 4,
            "num_heads": 8,
            "max_sequence_length": 24
        }
    }
}
