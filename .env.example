# Copy to `.env` (gitignored) and fill in your own values.
# Loaded automatically by src/data/config.py via python-dotenv.

# Your registered Earth Engine Cloud project ID (lowercase, hyphens — no underscores).
# Overrides the hardcoded default (ee-marlena) so you bill EE API calls against
# your own project. See docs/agents/planning/bow_valley/ARCHIVE_AUDIT.md §7.
EE_PROJECT=bow-valley-inference

# WANDB

WANDB_ENTITY`="sea-ice"

# --- Local-source pipeline data roots (src.data.local_sources.paths.LocalPaths) ---
# Each root is independent and may live on a different drive. If a variable is
# left unset, it defaults to the repo-relative path shown in the comment, so a
# fresh clone works with no config (everything lands under the repo's data/).
#
# To put data on real storage WITHOUT baking machine-specific paths into the
# repo, set absolute paths here (this file's copy, .env, is gitignored). This is
# the portable way to share the pipeline across machines/users: each clones the
# repo, copies this file to .env, and edits these five lines. No symlinks, no
# code edits, and subdirectories are created on the correct drive automatically.
# See data/BOW_VALLEY_DATA_LAYOUT.md §3.
#
# Defaults (repo-relative — uncomment only to be explicit):
# LOCAL_RAW_ROOT=data/bow_valley_selection_raw
# LOCAL_CLIPPED_ROOT=data/clipped_bow_valley_selection_raw
# LOCAL_PROCESSING_ROOT=data/bow_valley_processing
# LOCAL_AOI_PATH=data/bow_valley_inference_aoi.geojson
#
# Example absolute layout (one machine's storage — edit for yours):
# LOCAL_RAW_ROOT=/mnt/archive/bow_valley/selection_raw
# LOCAL_CLIPPED_ROOT=/mnt/archive/bow_valley/clipped_selection_raw
# LOCAL_PROCESSING_ROOT=/mnt/fast_scratch/bow_valley/processing
# LOCAL_AOI_PATH=/mnt/archive/bow_valley/inference_aoi.geojson
