# Copy to `.env` (gitignored) and fill in your own values.
# Loaded automatically by src/data/config.py via python-dotenv.

# Your registered Earth Engine Cloud project ID (lowercase, hyphens — no underscores).
# Overrides the hardcoded default (ee-marlena) so you bill EE API calls against
# your own project. See docs/agents/planning/bow_valley/ARCHIVE_AUDIT.md §7.
EE_PROJECT=bow-valley-inference

# --- Local-source pipeline data roots (src.data.local_sources.paths.LocalPaths) ---
# Defaults target the repo data/ layout; override to run the clip/assembly
# pipeline against another region or storage layout without editing code.
# See data/BOW_VALLEY_DATA_LAYOUT.md. Uncomment + set to override.
# LOCAL_RAW_ROOT=data/bow_valley_selection_raw
# LOCAL_CLIPPED_ROOT=data/clipped_bow_valley_selection_raw
# LOCAL_PROCESSING_ROOT=data/bow_valley_processing
# LOCAL_CUBE_ARCHIVE_ROOT=data/processed_bow_valley_cubes
# LOCAL_AOI_PATH=data/bow_valley_inference_aoi.geojson
