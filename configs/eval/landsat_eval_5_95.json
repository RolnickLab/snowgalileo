{
    "name": "landsat_eval_5_95",
    "data": {
        "label_folder": "landsat_eval_masks/all/patches_UTM_5_95_subset/",
        "input_tif_folder": "landsat_eval_tifs/patches_UTM_5_95_cropped/",
        "input_h5py_folder": "landsat_eval_h5pys_5_95/",
        "sklearn_train_data_checkpoint_folder": "sklearn_train_data_checkpoint",
        "label_resolution": 100,
        "num_timesteps": 8,
        "input_height_width": 100,
        "num_classes": 1,
        "split_type": "train_test_random",
        "dataset_subset_size": 0
    },
    "finetune": {
        "freeze_encoder": false,
        "token_mapping": "spatial_mean"
    },
    "linear_probe": {
        "freeze_encoder": true,
        "token_mapping": "spatial_mean"
    },
    "attention_probe": {
        "freeze_encoder": false,
        "token_mapping": "attention_probe",
        "n_heads": 2,
        "attn_dropout_p": 0.0,
        "use_tanh": false,
        "hidden_dim": 0,
        "attend_over_spatial": true
    },
    "hyperparameters_snowgalileo": {
        "augmentation": true,
        "batch_size": 2,
        "num_workers": 4,
        "weight_decay": 0,
        "schedule_sigmoid_slope": false,
        "sigmoid_slope": 1,
        "lr_schedule": false,
        "learning_rate": 0.003,
        "optimizer": "Adam",
        "adam_beta_2": 0.98,
        "warmup_fraction": 0.3,
        "loss_fn": "MSE",
        "med_and_low_res_repeat": false,
        "num_patches_per_dim": 10
    },
    "hyperparameters_rf": {
        "n_estimators": 300,
        "min_samples_leaf": 5
    },
    "hyperparameters_svr": {
        "kernel": "rbf",
        "C_base": 2,
        "C_exponent": -15,
        "degree": 2,
        "gamma_base": 2,
        "gamma_exponent": -5,
        "max_iter": 200
    },
    "hyperparameters_mlp": {
        "learning_rate_init": 0.001,
        "activation": "relu",
        "max_iter": 200
    }
}