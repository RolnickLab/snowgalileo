{
    "data": {
        "label_folder": "landsat_eval_masks/all/patches_UTM_1_99_test",
        "input_tif_folder": "landsat_eval_tifs/patches_UTM_1_99_test_cropped",
        "input_h5py_folder": "landsat_eval_h5pys_1_99_test/",
        "label_resolution": 100,
        "num_timesteps": 8,
        "input_height_width": 100,
        "num_classes": 1
    },
    "finetune": {
        "freeze_encoder": false,
        "token_mapping": "spatial_mean"
    },
    "linear_probe": {
        "freeze_encoder": true,
        "token_mapping": "spatial_mean"
    },
    "attention_probe": {
        "freeze_encoder": true,
        "token_mapping": "attention"
    },
    "hyperparams": {
        "batch_size": 16,
        "num_workers": 4,
        "weight_decay": 0.0,
        "sigmoid_slope": 1.0,
        "lr_schedule": true,
        "learning_rate": 0.1,
        "optimizer": "Adam",
        "warmup_fraction": 0.1,
        "loss_fn": "MSE"
    }
}